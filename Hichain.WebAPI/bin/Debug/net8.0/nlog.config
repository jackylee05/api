<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      internalLogLevel="Off"
      internalLogFile="${basedir}/LOG/nlog-internal.log"
      autoReload="true"
      throwConfigExceptions="true">

  <targets>
    <!-- 写日志到运行目录下的 LOG 文件夹，按日期分文件 -->
    <target xsi:type="File"
            name="allfile"
            fileName="${basedir}/LOG/${shortdate}.log"
            createDirs="true"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />

    <!-- 同时输出到控制台窗口，方便查看监听端口等信息 -->
    <target xsi:type="Console"
            name="console"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />
  </targets>

  <rules>
    <!-- 仅 Info 及以上写入文件和控制台（与 Program.cs 中 MinimumLevel.Information 一致） -->
    <logger name="*" minlevel="Info" writeTo="allfile,console" />
  </rules>

</nlog>

